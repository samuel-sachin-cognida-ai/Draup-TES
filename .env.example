# ──────────────────────────────────────────────────
# LLM Configuration (provider-agnostic via OpenAI API)
# ──────────────────────────────────────────────────

# Primary API key
LLM_API_KEY=your_api_key_here

# Optional: additional keys for automatic failover on rate limits
# LLM_API_KEY_2=your_second_key
# LLM_API_KEY_3=your_third_key
# LLM_API_KEYS=key1,key2,key3   # comma-separated alternative

# API base URL — change to use a different provider:
#   Groq  : https://api.groq.com/openai/v1
#   Gemini: https://generativelanguage.googleapis.com/v1beta/openai/
#   OpenAI: https://api.openai.com/v1
LLM_BASE_URL=https://api.groq.com/openai/v1

# Model name (must match your provider)
#   Groq  : llama-3.3-70b-versatile
#   Gemini: gemini-2.0-flash-lite
#   OpenAI: gpt-4o-mini
LLM_MODEL=llama-3.3-70b-versatile

# ──────────────────────────────────────────────────
# PostgreSQL
# ──────────────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_DBNAME=healthcare_crawler
PG_USER=postgres
PG_PASSWORD=your_db_password_here

# ──────────────────────────────────────────────────
# Crawler tuning
# ──────────────────────────────────────────────────

# Parallel LLM extraction workers (per crawler)
LLM_WORKERS=3

# Max pages to visit — Claude crawler
MAX_PAGES=60

# Max pages to visit — OpenAI crawler
MAX_PAGES_OPENAI=80

# Stop crawling when this many distinct sub-offerings are found — Claude
TARGET_SUB_OFFERINGS=25

# Stop crawling when this many distinct sub-offerings are found — OpenAI
TARGET_SUB_OFFERINGS_OPENAI=25
